<Window x:Class="DataBaseManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ManagerUI"
        Height="550"
        Width="720">

    <Grid Margin="40">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>

            <!-- SOURCE -->
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="35"/>

            <RowDefinition Height="20"/>

            <!-- DESTINATION -->
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="35"/>

            <RowDefinition Height="40"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>


        <!-- TITLE -->

        <TextBlock Grid.Row="0"
                   Grid.ColumnSpan="3"
                   Text="Database Transfer"
                   FontSize="26"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>


        <!-- SOURCE SERVER -->

        <TextBlock Grid.Row="1"
                   Grid.Column="0"
                   Text="Source Server:"
                   VerticalAlignment="Center"
                   TextAlignment="Right"
                   Margin="0,0,5,5"/>

        <TextBox x:Name="SServerTxt"
                 Grid.Row="1"
                 Grid.Column="1"
                 Margin="0,0,0,5"/>

        <Label x:Name="SServerLbl"
               Grid.Row="1"
               Grid.Column="2"
               VerticalAlignment="Center"/>



        <!-- SOURCE DATABASE -->

        <TextBlock Grid.Row="2"
                   Grid.Column="0"
                   Text="Source Database:"
                   VerticalAlignment="Center"
                   TextAlignment="Right"
                   Margin="0,0,5,5"/>

        <TextBox x:Name="SDatabaseTxt"
                 Grid.Row="2"
                 Grid.Column="1"
                 Margin="0,0,0,5"/>

        <Label x:Name="SDatabaseLbl"
               Grid.Row="2"
               Grid.Column="2"
               VerticalAlignment="Center"/>



        <!-- SOURCE TABLE -->

        <TextBlock Grid.Row="3"
                   Grid.Column="0"
                   Text="Source Table:"
                   VerticalAlignment="Center"
                   TextAlignment="Right"
                   Margin="0,0,5,5"/>

        <TextBox x:Name="STableTxt"
                 Grid.Row="3"
                 Grid.Column="1"
                 Margin="0,0,0,5"/>

        <Label x:Name="STableLbl"
               Grid.Row="3"
               Grid.Column="2"
               VerticalAlignment="Center"/>



        <Button Grid.Row="4"
                Grid.Column="1"
                Width="150"
                Margin="0,5,0,5"
                Content="Check Source"
                Click="CheckSource_OnClick"/>



        <!-- DESTINATION SERVER -->

        <TextBlock Grid.Row="6"
                   Grid.Column="0"
                   Text="Destination Server:"
                   VerticalAlignment="Center"
                   TextAlignment="Right"
                   Margin="0,0,5,5"/>

        <TextBox x:Name="DServerTxt"
                 Grid.Row="6"
                 Grid.Column="1"
                 Margin="0,0,0,5"/>

        <Label x:Name="DServerLbl"
               Grid.Row="6"
               Grid.Column="2"
               VerticalAlignment="Center"/>



        <!-- DESTINATION DATABASE -->

        <TextBlock Grid.Row="7"
                   Grid.Column="0"
                   Text="Destination Database:"
                   VerticalAlignment="Center"
                   TextAlignment="Right"
                   Margin="0,0,5,5"/>

        <TextBox x:Name="DDatabaseTxt"
                 Grid.Row="7"
                 Grid.Column="1"
                 Margin="0,0,0,5"/>

        <Label x:Name="DDatabaseLbl"
               Grid.Row="7"
               Grid.Column="2"
               VerticalAlignment="Center"/>



        <!-- DESTINATION TABLE -->

        <TextBlock Grid.Row="8"
                   Grid.Column="0"
                   Text="Destination Table:"
                   VerticalAlignment="Center"
                   TextAlignment="Right"
                   Margin="0,0,5,5"/>

        <TextBox x:Name="DTableTxt"
                 Grid.Row="8"
                 Grid.Column="1"
                 Margin="0,0,0,5"/>

        <Label x:Name="DTableLbl"
               Grid.Row="8"
               Grid.Column="2"
               VerticalAlignment="Center"/>



        <Button Grid.Row="9"
                Grid.Column="1"
                Width="170"
                Margin="0,5,0,5"
                Content="Check Destination"
                Click="CheckDestination_OnClick"/>



        <!-- TRANSFER BUTTON -->

        <Button Grid.Row="10"
                Grid.Column="1"
                Width="170"
                Margin="0,10,0,10"
                Content="Transfer Data"
                Click="TransferData_OnClick"/>



        <!-- GENERAL ERROR LABEL -->

        <Label Grid.Row="12"
               Grid.Column="0"
               Grid.ColumnSpan="3"
               x:Name="ErrorLbl"
               Foreground="Red"
               HorizontalContentAlignment="Center"
               Margin="0,5,0,0"/>

    </Grid>
</Window>