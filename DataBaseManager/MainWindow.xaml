<Window x:Class="DataBaseManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ManagerUI"
        Height="500"
        Width="700">

    <Grid Margin="40">

        <!-- Grid Structure -->
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <!-- Title -->
            <RowDefinition Height="20"/>

            <RowDefinition Height="30"/>
            <!-- Source Server -->
            <RowDefinition Height="30"/>
            <!-- Source Database -->
            <RowDefinition Height="30"/>
            <!-- Source Table -->
            <RowDefinition Height="Auto"/>
            <!-- Check Source -->
            <RowDefinition Height="10"/>

            <RowDefinition Height="30"/>
            <!-- Destination Server -->
            <RowDefinition Height="30"/>
            <!-- Destination Database -->
            <RowDefinition Height="30"/>
            <!-- Destination Table -->
            <RowDefinition Height="Auto"/>
            <!-- Check Destination -->
            <RowDefinition Height="Auto"/>
            <!-- Transfer -->
            <RowDefinition Height="Auto"/>
            <!-- Status -->
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="200"/>
        </Grid.ColumnDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Grid.ColumnSpan="3"
                   Text="Database Transfer"
                   FontSize="26"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <!-- SOURCE SECTION -->

        <TextBlock Grid.Row="2" Grid.Column="0"
                   Text="Source Server:"
                   VerticalAlignment="Center"
                   Margin="0,0,3,5"
                   TextAlignment="Right"/>
        <TextBox x:Name="SServerTxt"
                 Grid.Row="2" Grid.Column="1"
                 Margin="0,0,0,5"/>
        <Label x:Name="SServerErrLbl"
               Grid.Row="2" Grid.Column="2"
               Foreground="Red"
               Margin="0,0,0,5"/>

        <TextBlock Grid.Row="3" Grid.Column="0"
                   Text="Source Database:"
                   VerticalAlignment="Center"
                   Margin="0,0,3,5"
                   TextAlignment="Right"/>
        <TextBox x:Name="SDatabaseTxt"
                 Grid.Row="3" Grid.Column="1"
                 Margin="0,0,0,5"/>
        <Label x:Name="SDatabaseErrLbl"
               Grid.Row="3" Grid.Column="2"
               Foreground="Red"
               Margin="0,0,0,5"/>

        <TextBlock Grid.Row="4" Grid.Column="0"
                   Text="Source Table:"
                   VerticalAlignment="Center"
                   Margin="0,0,3,5"
                   TextAlignment="Right"/>
        <TextBox x:Name="SDataTableTxt"
                 Grid.Row="4" Grid.Column="1"
                 Margin="0,0,0,5"/>
        <Label x:Name="SDataTableErrLbl"
               Grid.Row="4" Grid.Column="2"
               Foreground="Red"
               Margin="0,0,0,5"/>

        <Button Grid.Row="5"
                Grid.Column="1"
                Content="Check Source"
                Width="150"
                Margin="0,5,0,5"
                Click="CheckSource_OnClick"/>

        <!-- DESTINATION SECTION -->

        <TextBlock Grid.Row="7" Grid.Column="0"
                   Text="Destination Server:"
                   VerticalAlignment="Center"
                   Margin="0,0,3,5"
                   TextAlignment="Right"/>
        <TextBox x:Name="DServerTxt"
                 Grid.Row="7" Grid.Column="1"
                 Margin="0,0,0,5"/>
        <Label x:Name="DServerErrLbl"
               Grid.Row="7" Grid.Column="2"
               Foreground="Red"
               Margin="0,0,0,5"/>

        <TextBlock Grid.Row="8" Grid.Column="0"
                   Text="Destination Database:"
                   VerticalAlignment="Center"
                   Margin="0,0,3,5"
                   TextAlignment="Right"/>
        <TextBox x:Name="DDatabaseTxt"
                 Grid.Row="8" Grid.Column="1"
                 Margin="0,0,0,5"/>
        <Label x:Name="DDatabaseErrLbl"
               Grid.Row="8" Grid.Column="2"
               Foreground="Red"
               Margin="0,0,0,5"/>

        <TextBlock Grid.Row="9" Grid.Column="0"
                   Text="Destination Table:"
                   VerticalAlignment="Center"
                   Margin="0,0,3,5"
                   TextAlignment="Right"/>
        <TextBox x:Name="DDataTableTxt"
                 Grid.Row="9" Grid.Column="1"
                 Margin="0,0,0,5"/>
        <Label x:Name="DDataTableErrLbl"
               Grid.Row="9" Grid.Column="2"
               Foreground="Red"
               Margin="0,0,0,5"/>

        <Button Grid.Row="10"
                Grid.Column="1"
                Content="Check Destination"
                Width="170"
                Margin="0,5,0,5"
                Click="CheckDestination_OnClick"/>

        <Button Grid.Row="11"
                Grid.Column="1"
                Content="Transfer Data"
                Width="170"
                Margin="0,5,0,5"
                Click="TransferData_OnClick"/>

        <Label Grid.Row="12"
               Grid.Column="1"
               Grid.ColumnSpan="2"
               Foreground="Green"
               Margin="0,10,0,0"
               HorizontalContentAlignment="Center"/>

    </Grid>
</Window>